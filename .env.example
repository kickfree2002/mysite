# SBI証券 HyperSBI2 API 設定テンプレート
# このファイルをコピーして .env にリネームし、実際の値を入力してください
# cp .env.example .env

# ===== SBI証券 ログイン情報 =====
SBI_USERNAME=your_username_here
SBI_PASSWORD=your_password_here

# ===== HyperSBI2 API エンドポイント =====
# ベースURL (通常変更不要)
HYPERSBI2_BASE_URL=https://site3.sbisec.co.jp/ETGate/
HYPERSBI2_API_BASE_URL=https://kabuka.sbisec.co.jp/api/

# ===== 認証設定 =====
# トークンの有効期限(秒)
TOKEN_EXPIRY_SECONDS=3600
# セッションタイムアウト(秒)
SESSION_TIMEOUT=1800

# ===== 監視設定 =====
# 価格取得間隔(秒) - 市場開放時
MONITOR_INTERVAL_SECONDS=5
# 価格取得間隔(秒) - 市場閉鎖時
MONITOR_INTERVAL_CLOSED=60
# 監視対象銘柄コード (カンマ区切り)
WATCH_SYMBOLS=7203,9984,6758

# ===== ログ設定 =====
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# ===== アラート設定 =====
# 価格変動アラート閾値(%)
PRICE_ALERT_THRESHOLD=2.0
