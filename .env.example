# kabuステーション API 設定テンプレート
# このファイルをコピーして .env にリネームし、実際の値を入力してください
# cp .env.example .env

# ===== kabuステーション API 設定 =====
# kabuステーションを起動した状態で使用してください
# APIパスワード (kabuステーション > 環境設定 > API で確認)
KABU_API_PASSWORD=your_api_password_here

# APIサーバーのベースURL (通常変更不要)
KABU_BASE_URL=http://localhost:18080

# ===== 監視設定 =====
# 価格取得間隔(秒) - REST ポーリングモード使用時
MONITOR_INTERVAL_SECONDS=3
# 監視対象銘柄コード@取引所コード (カンマ区切り)
# 取引所コード: 1=東証プライム 3=東証スタンダード 5=東証グロース
WATCH_SYMBOLS=7203@1,9984@1,6758@1

# ===== 監視モード =====
# websocket: リアルタイムPush受信 (推奨)
# polling:   REST APIを定期ポーリング
MONITOR_MODE=websocket

# ===== アラート設定 =====
# 価格変動アラート閾値(%)
PRICE_ALERT_THRESHOLD=2.0

# ===== ログ設定 =====
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
